.live-badge { padding: 6px 12px; border-radius: 20px; background: var(--bg-card); border: 1px solid var(--border); font-size: 12px; font-weight: 600; display: flex; align-items: center; gap: 6px; }

.live-badge .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--text-secondary); }

.live-badge.live .dot { background: var(--success); animation: 2s ease 0s infinite normal none running pulse; }

@keyframes pulse { 
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.deck-container { margin-top: var(--nav-height); height: calc(100vh - var(--nav-height)); overflow: scroll hidden; scroll-snap-type: x mandatory; display: flex; scroll-behavior: smooth; }

.slide { min-width: 100vw; height: 100%; scroll-snap-align: start; padding: 48px 64px; display: flex; flex-direction: column; justify-content: center; position: relative; overflow-y: auto; }

.slide-number { position: absolute; top: 24px; right: 24px; color: var(--text-secondary); font-size: 14px; font-weight: 600; }

h1 { font-size: clamp(36px, 5vw, 64px); font-weight: 800; line-height: 1.1; margin-bottom: 24px; letter-spacing: -1.5px; }

h2 { font-size: clamp(28px, 4vw, 48px); font-weight: 700; margin-bottom: 32px; letter-spacing: -1px; }

h3 { font-size: 24px; font-weight: 600; margin-bottom: 16px; color: var(--accent); }

.subtitle { font-size: clamp(18px, 2vw, 24px); color: var(--text-secondary); margin-bottom: 32px; font-weight: 400; }

.gradient-text { background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; }

.slide-cover { background: radial-gradient(circle at 20% 50%, var(--accent-glow) 0%, transparent 50%); text-align: center; align-items: center; }

.slide-cover .hero-badge { display: inline-block; padding: 8px 20px; background: var(--accent-glow); border: 1px solid var(--accent); border-radius: 30px; font-size: 14px; font-weight: 600; color: var(--accent); margin-bottom: 32px; }

.slide-cover .ask-amount { font-size: clamp(32px, 4vw, 56px); font-weight: 800; margin-top: 24px; color: var(--accent); }

.card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-top: 32px; }

.card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 32px; transition: 0.3s; box-shadow: 0 4px 12px var(--shadow); }

.card:hover { transform: translateY(-8px); border-color: var(--accent); box-shadow: 0 12px 24px var(--shadow), 0 0 0 1px var(--accent-glow); }

.card-icon { width: 48px; height: 48px; background: var(--accent-glow); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; font-size: 24px; }

.card h4 { font-size: 20px; margin-bottom: 12px; font-weight: 600; }

.card p { color: var(--text-secondary); line-height: 1.6; }

.metrics { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 20px; margin: 32px 0px; }

.metric { text-align: center; padding: 24px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; transition: 0.3s; }

.metric:hover { transform: scale(1.05); border-color: var(--accent); }

.metric-value { font-size: 40px; font-weight: 800; color: var(--accent); line-height: 1; margin-bottom: 8px; }

.metric-label { font-size: 14px; color: var(--text-secondary); font-weight: 500; }

.team-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 32px; margin-top: 32px; }

.team-card { text-align: center; padding: 32px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; transition: 0.3s; }

.team-card:hover { transform: translateY(-8px); border-color: var(--accent); }

.team-photo { width: 120px; height: 120px; border-radius: 50%; border: 4px solid var(--accent); margin: 0px auto 20px; background: var(--bg-secondary); display: flex; align-items: center; justify-content: center; font-size: 48px; font-weight: 700; color: var(--accent); position: relative; overflow: hidden; }

.team-card h4 { font-size: 20px; margin-bottom: 8px; }

.team-role { color: var(--text-secondary); font-size: 14px; margin-bottom: 16px; }

.linkedin-btn { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px; color: var(--text-primary); text-decoration: none; font-size: 14px; transition: 0.2s; }

.linkedin-btn:hover { background: rgb(0, 119, 181); border-color: rgb(0, 119, 181); color: white; }

.btn-dataroom { display: inline-flex; align-items: center; gap: 10px; padding: 14px 28px; background: transparent; border: 2px solid rgb(200, 148, 58); border-radius: 12px; color: rgb(200, 148, 58); text-decoration: none; font-size: 16px; font-weight: 600; transition: 0.3s; margin-top: 16px; cursor: pointer; }

.btn-dataroom:hover { background: rgb(200, 148, 58); color: var(--bg-primary); transform: translateY(-2px); box-shadow: rgba(200, 148, 58, 0.3) 0px 8px 20px; }

.btn-dataroom svg { width: 18px; height: 18px; }

.chart-container { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 32px; margin-top: 32px; max-height: 400px; }

.chart-container canvas { max-height: 320px; }

.timeline-container { margin-top: 32px; overflow-x: auto; padding-bottom: 24px; scroll-snap-type: x mandatory; cursor: grab; }

.timeline-container:active { cursor: grabbing; }

.timeline { display: flex; gap: 24px; padding: 24px 0px; min-width: max-content; }

.timeline-item { scroll-snap-align: start; min-width: 280px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 24px; cursor: pointer; transition: 0.3s; position: relative; }

.timeline-item:hover { transform: translateY(-8px); border-color: var(--accent); box-shadow: 0 12px 24px var(--shadow); }

.timeline-item::before { content: ""; position: absolute; top: 50%; left: -24px; width: 24px; height: 2px; background: var(--border); }

.timeline-item:first-child::before { display: none; }

.timeline-date { font-size: 14px; font-weight: 700; color: var(--accent); margin-bottom: 12px; }

.timeline-title { font-size: 18px; font-weight: 600; margin-bottom: 8px; }

.timeline-desc { font-size: 14px; color: var(--text-secondary); }

.progress-dots { position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%); display: flex; gap: 12px; z-index: 999; background: var(--bg-secondary); padding: 12px 24px; border-radius: 30px; border: 1px solid var(--border); box-shadow: 0 4px 12px var(--shadow); }

.dot-indicator { width: 10px; height: 10px; border-radius: 50%; background: var(--border); cursor: pointer; transition: 0.3s; }

.dot-indicator.active { background: var(--accent); transform: scale(1.4); }

.dot-indicator:hover { background: var(--accent-light); }

.modal { display: none; position: fixed; inset: 0px; background: rgba(0, 0, 0, 0.8); backdrop-filter: blur(8px); z-index: 2000; align-items: center; justify-content: center; padding: 24px; }

.modal.active { display: flex; }

.modal-content { background: var(--bg-card); border: 1px solid var(--border); border-radius: 20px; padding: 40px; max-width: 600px; width: 100%; position: relative; animation: 0.3s ease 0s 1 normal none running modalIn; }

@keyframes modalIn { 
  0% { opacity: 0; transform: scale(0.9); }
  100% { opacity: 1; transform: scale(1); }
}

.modal-close { position: absolute; top: 16px; right: 16px; width: 36px; height: 36px; border-radius: 50%; background: var(--bg-secondary); border: 1px solid var(--border); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 20px; transition: 0.2s; }

.modal-close:hover { background: var(--danger); border-color: var(--danger); color: white; }

.command-palette { display: none; position: fixed; top: 20%; left: 50%; transform: translateX(-50%); width: 90%; max-width: 600px; background: var(--bg-card); border: 1px solid var(--accent); border-radius: 16px; box-shadow: 0 20px 60px var(--shadow); z-index: 3000; overflow: hidden; }

.command-palette.active { display: block; animation: 0.2s ease 0s 1 normal none running modalIn; }

.command-input { width: 100%; padding: 20px 24px; background: transparent; border-top-width: medium; border-right-width: medium; border-left-width: medium; border-top-style: none; border-right-style: none; border-left-style: none; border-top-color: currentcolor; border-right-color: currentcolor; border-left-color: currentcolor; border-image: initial; border-bottom: 1px solid var(--border); color: var(--text-primary); font-size: 16px; outline: none; }

.command-results { max-height: 400px; overflow-y: auto; }

.command-item { padding: 16px 24px; cursor: pointer; transition: 0.2s; border-bottom: 1px solid var(--border); }

.command-item:hover, .command-item.selected { background: var(--accent-glow); }

.command-item-title { font-weight: 600; margin-bottom: 4px; }

.command-item-desc { font-size: 14px; color: var(--text-secondary); }

.investor-mode-hidden { display: none !important; }

@media print {
  nav, .progress-dots, .icon-btn, .live-badge { display: none !important; }
  .deck-container { overflow: visible; height: auto; display: block; }
  .slide { min-width: 100%; height: auto; break-after: page; padding: 40px; }
  .slide:last-child { break-after: auto; }
  body { overflow: visible; }
}

@media (max-width: 768px) {
  .slide { padding: 32px 24px; }
  h1 { font-size: 36px; }
  h2 { font-size: 28px; }
  .metrics { grid-template-columns: repeat(2, 1fr); }
  .card-grid, .team-grid { grid-template-columns: 1fr; }
  .logo-text { display: none; }
  nav { padding: 0px 16px; }
}

.hidden { display: none; }
